<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_accent }}">
    <title>{{ shop.name }} &ndash; {{ 'general.password_page.opening_soon' | t }}</title>
    {{ content_for_header }}
    <style>
      :root {
        --color-background: {{ settings.color_background }};
        --color-surface: {{ settings.color_surface }};
        --color-text: {{ settings.color_text }};
        --color-muted: {{ settings.color_muted_text }};
        --color-border: {{ settings.color_border }};
        --color-accent: {{ settings.color_accent }};
        --color-accent-contrast: {{ settings.color_button_text }};
        --page-width: {{ settings.page_width }}px;
        --radius-button: {{ settings.button_radius }}px;
      }
    </style>
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-password">
    <main id="MainContent" class="password-main" role="main">
      {{ content_for_layout }}
    </main>
  </body>
</html>
