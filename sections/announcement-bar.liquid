{%- if section.settings.text != blank -%}
  <div class="announcement-bar" style="--announcement-background: {{ section.settings.background }}; --announcement-text: {{ section.settings.text_color }};">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">{{ section.settings.text | escape }}</a>
    {%- else -%}
      <p class="announcement-bar__text">{{ section.settings.text | escape }}</p>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "Free shipping on orders over $75" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "color", "id": "background", "label": "Background", "default": "#1d6f5f" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" }
  ]
}
{% endschema %}
