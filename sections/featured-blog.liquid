{%- assign selected_blog = section.settings.blog -%}
<section class="section-spacing">
  <div class="page-width">
    <div class="section-header"><h2>{{ section.settings.heading | escape }}</h2>{% if selected_blog != blank %}<a href="{{ selected_blog.url }}">{{ 'collections.general.view_all' | t }}</a>{% endif %}</div>
    <div class="grid grid--3">
      {%- if selected_blog != blank -%}
        {%- for article in selected_blog.articles limit: 3 -%}
          <article class="article-card">
            {%- if article.image -%}<a class="article-card__media" href="{{ article.url }}">{{ article.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 600, 900', sizes: '(min-width: 990px) 33vw, 100vw', alt: article.title | escape }}</a>{%- endif -%}
            <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
            <p>{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured blog",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stories and guides" },
    { "type": "blog", "id": "blog", "label": "Blog" }
  ],
  "presets": [{ "name": "Featured blog" }]
}
{% endschema %}
