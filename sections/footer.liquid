<footer class="site-footer section-spacing">
  <div class="page-width">
    <div class="footer__grid">
      {%- for block in section.blocks -%}
        <div class="footer__block" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'link_list' -%}
              <h2 class="footer__heading">{{ block.settings.heading | escape }}</h2>
              {%- assign footer_menu = linklists[block.settings.menu] -%}
              <ul class="footer__links">
                {%- for link in footer_menu.links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}
              </ul>
            {%- when 'text' -%}
              <h2 class="footer__heading">{{ block.settings.heading | escape }}</h2>
              <div class="rte">{{ block.settings.text }}</div>
            {%- when 'newsletter' -%}
              <h2 class="footer__heading">{{ block.settings.heading | escape }}</h2>
              <p>{{ block.settings.text }}</p>
              {%- form 'customer', class: 'newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input class="input" type="email" name="contact[email]" aria-label="{{ 'newsletter.label' | t }}" placeholder="{{ 'newsletter.label' | t }}" required>
                <button class="button" type="submit">{{ 'newsletter.button_label' | t }}</button>
              {%- endform -%}
            {%- when 'social' -%}
              <h2 class="footer__heading">{{ block.settings.heading | escape }}</h2>
              {% render 'social-links' %}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
      <span>{{ powered_by_link }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "About Masarima" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Thoughtful products for everyday rituals.</p>" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in touch" },
        { "type": "text", "id": "text", "label": "Text", "default": "New arrivals, offers, and stories from the studio." }
      ]
    },
    {
      "type": "social",
      "name": "Social links",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Follow" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list" },
      { "type": "text" },
      { "type": "newsletter" },
      { "type": "social" }
    ]
  }
}
{% endschema %}
