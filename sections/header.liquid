{%- assign main_menu = linklists[section.settings.menu] -%}
<header class="site-header{% if section.settings.sticky_header %} site-header--sticky{% endif %}">
  <div class="page-width header__inner">
    <details class="mobile-menu" data-mobile-menu>
      <summary class="icon-button mobile-menu__toggle" aria-label="{{ 'general.accessibility.menu' | t }}">{% render 'icon', icon: 'menu' %}</summary>
      <div class="mobile-menu__panel">
        <nav class="mobile-menu__links" aria-label="Mobile menu">
          {%- for link in main_menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        </nav>
      </div>
    </details>

    <div class="header__heading">
      <a class="header__heading-link" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_style = '--logo-width: ' | append: section.settings.logo_width | append: 'px;' -%}
          {{ section.settings.logo | image_url: width: 440 | image_tag: class: 'header__logo', widths: '160, 240, 320, 440', alt: logo_alt, style: logo_style }}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
    </div>

    <nav class="header__nav" aria-label="Primary menu">
      {%- for link in main_menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="header__actions">
      {%- if section.settings.show_search -%}
        <a class="icon-button" href="{{ routes.search_url }}" aria-label="{{ 'general.accessibility.search' | t }}">{% render 'icon', icon: 'search' %}</a>
      {%- endif -%}
      <a class="icon-button" href="{{ routes.account_url }}" aria-label="{{ 'general.accessibility.account' | t }}">{% render 'icon', icon: 'account' %}</a>
      <a class="icon-button" href="{{ routes.cart_url }}" aria-label="{{ 'general.accessibility.cart' | t }}">
        {% render 'icon', icon: 'bag' %}
        {%- if cart.item_count > 0 -%}<span class="cart-count">{{ cart.item_count }}</span>{%- endif -%}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 80, "max": 260, "step": 10, "unit": "px", "default": 140 },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "checkbox", "id": "sticky_header", "label": "Enable sticky header", "default": true },
    { "type": "checkbox", "id": "show_search", "label": "Show search", "default": true }
  ]
}
{% endschema %}
