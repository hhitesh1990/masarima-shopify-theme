<section class="hero{% if section.settings.image != blank %} hero--image{% endif %}" style="--hero-height: {{ section.settings.height }}vh; --hero-background: {{ section.settings.background }}; --hero-text: {{ section.settings.text_color }};">
  {%- if section.settings.image != blank -%}
    <div class="hero__media">
      {%- assign hero_alt = section.settings.image.alt | default: section.settings.heading | escape -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', widths: '720, 1000, 1400, 1800, 2400', sizes: '100vw', alt: hero_alt }}
    </div>
  {%- endif -%}
  <div class="page-width hero__content">
    {%- if section.settings.eyebrow != blank -%}<p class="hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
    <h1 class="hero__heading">{{ section.settings.heading | escape }}</h1>
    {%- if section.settings.text != blank -%}<div class="hero__text rte">{{ section.settings.text }}</div>{%- endif -%}
    <div class="hero__buttons">
      {%- if section.settings.primary_label != blank -%}<a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label | escape }}</a>{%- endif -%}
      {%- if section.settings.secondary_label != blank -%}<a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label | escape }}</a>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Masarima essentials" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beautiful goods for daily living" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Curated pieces designed to bring calm, utility, and warmth into the routines you return to every day.</p>" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop new arrivals" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Explore collections" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "range", "id": "height", "label": "Height", "min": 45, "max": 85, "step": 5, "unit": "vh", "default": 70 },
    { "type": "color", "id": "background", "label": "Background", "default": "#1f2a24" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#ffffff" }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
