<section class="section-spacing">
  <div class="page-width image-with-text{% if section.settings.layout == 'text_first' %} image-with-text--reverse{% endif %}">
    <div class="image-with-text__media" {% if section.settings.layout == 'text_first' %}style="order: 2;"{% endif %}>
      {%- if section.settings.image != blank -%}
        {%- assign image_alt = section.settings.image.alt | default: section.settings.heading | escape -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '500, 800, 1100, 1400', sizes: '(min-width: 990px) 50vw, 100vw', alt: image_alt }}
      {%- endif -%}
    </div>
    <div class="image-with-text__content rte">
      <p class="hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2>{{ section.settings.heading | escape }}</h2>
      {{ section.settings.text }}
      {%- if section.settings.button_label != blank -%}<a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label | escape }}</a>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our point of view" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Designed with purpose" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use this section to tell the story behind your products, materials, process, or promise.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Learn more" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "layout", "label": "Layout", "default": "image_first", "options": [
      { "value": "image_first", "label": "Image first" },
      { "value": "text_first", "label": "Text first" }
    ]}
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
