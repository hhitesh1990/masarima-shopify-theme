<section class="section-spacing">
  <div class="container">
    <div class="flex justify-between items-start mb-6">
      <h1>{{ 'customer.account.title' | t }}</h1>
      <a class="button button--text" href="{{ routes.account_logout_url }}">{{ 'customer.log_out' | t }}</a>
    </div>
    <div class="grid grid--2">
      <div class="card">
        <h2 class="h5">{{ 'customer.orders.title' | t }}</h2>
        {%- if customer.orders.size > 0 -%}
          <div class="grid">
            {%- for order in customer.orders -%}
              <a href="{{ order.customer_url }}">{{ order.name }} - {{ order.created_at | time_tag: format: 'date' }}</a>
            {%- endfor -%}
          </div>
        {%- else -%}
          <p>{{ 'customer.orders.none' | t }}</p>
        {%- endif -%}
      </div>
      <div class="card">
        <h2 class="h5">{{ 'customer.account.details' | t }}</h2>
        <p>{{ customer.name }}<br>{{ customer.email }}</p>
        <a href="{{ routes.account_addresses_url }}">{{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main account",
  "settings": []
}
{% endschema %}
