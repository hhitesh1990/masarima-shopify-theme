<article class="section-spacing">
  <div class="page-width customer-layout">
    <p class="hero__eyebrow">{{ article.published_at | time_tag: format: 'date' }}</p>
    <h1>{{ article.title }}</h1>
    {%- if article.image -%}{{ article.image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '700, 1000, 1400', sizes: '100vw', alt: article.title | escape }}{%- endif -%}
    <div class="rte">{{ article.content }}</div>
    <a href="{{ blog.url }}">{{ 'blogs.article.back_to_blog' | t }}</a>
  </div>
</article>

{% schema %}
{ "name": "Article" }
{% endschema %}
