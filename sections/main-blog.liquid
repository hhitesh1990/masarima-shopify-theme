<section class="section-spacing">
  <div class="page-width">
    <h1>{{ blog.title }}</h1>
    {%- paginate blog.articles by section.settings.articles_per_page -%}
      <div class="grid grid--3">
        {%- for article in blog.articles -%}
          <article class="article-card">
            {%- if article.image -%}<a class="article-card__media" href="{{ article.url }}">{{ article.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 600, 900', sizes: '(min-width: 990px) 33vw, 100vw', alt: article.title | escape }}</a>{%- endif -%}
            <h2 class="h3"><a href="{{ article.url }}">{{ article.title }}</a></h2>
            <p>{{ article.excerpt_or_content | strip_html | truncate: 150 }}</p>
            <a href="{{ article.url }}">{{ 'blogs.article.read_more' | t }}</a>
          </article>
        {%- endfor -%}
      </div>
      {% render 'pagination', paginate: paginate %}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": [
    { "type": "range", "id": "articles_per_page", "label": "Articles per page", "min": 3, "max": 24, "step": 3, "default": 9 }
  ]
}
{% endschema %}
