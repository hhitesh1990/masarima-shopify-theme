<section class="section-spacing">
  <div class="container">
    <h1>{{ blog.title }}</h1>
    {%- paginate blog.articles by 12 -%}
      <div class="grid grid--3">
        {%- for article in blog.articles -%}
          <article class="article-card card">
            {%- if article.image != blank -%}
              <a class="article-card__media media media--wide" href="{{ article.url }}">
                {% render 'responsive-image', image: article.image, loading: 'lazy', sizes: '(min-width: 990px) 33vw, 100vw' %}
              </a>
            {%- endif -%}
            <div class="article-card__meta">
              <p class="article-card__date">{{ article.published_at | time_tag: format: 'date' }}</p>
              <h2 class="article-card__title h5"><a href="{{ article.url }}">{{ article.title }}</a></h2>
              {%- if article.excerpt_or_content != blank -%}<div class="card__text rte">{{ article.excerpt_or_content | strip_html | truncate: 140 }}</div>{%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": []
}
{% endschema %}
