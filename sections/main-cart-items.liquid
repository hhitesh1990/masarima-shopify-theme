<section class="section-spacing">
  <div class="page-width">
    <h1>{{ 'cart.general.title' | t }}</h1>
    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item">
              <a class="cart-item__media" href="{{ item.url }}">{% if item.image %}{{ item.image | image_url: width: 220 | image_tag: loading: 'lazy', alt: item.title | escape }}{% endif %}</a>
              <div>
                <p class="cart-item__title"><a href="{{ item.url }}">{{ item.product.title }}</a></p>
                {%- unless item.product.has_only_default_variant -%}<p>{{ item.variant.title }}</p>{%- endunless -%}
                <p>{{ item.final_line_price | money }}</p>
                <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">{{ 'products.product.quantity' | t }}</label>
                <div class="quantity" data-quantity>
                  <button type="button" data-quantity-adjust="-1" aria-label="Decrease quantity">−</button>
                  <input id="Quantity-{{ item.index | plus: 1 }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                  <button type="button" data-quantity-adjust="1" aria-label="Increase quantity">+</button>
                </div>
                <a href="{{ item.url_to_remove }}">{{ 'cart.general.remove' | t }}</a>
              </div>
              <div class="cart-item__total">{{ item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
        </div>
        <div class="cart-summary">
          <label class="field" for="CartNote">{{ 'cart.general.note' | t }}<textarea id="CartNote" name="note">{{ cart.note }}</textarea></label>
          <div class="cart-summary__row"><span>{{ 'cart.general.subtotal' | t }}</span><span>{{ cart.total_price | money_with_currency }}</span></div>
          <p>{{ 'cart.general.taxes_and_shipping_policy_at_checkout_html' | t }}</p>
          <button class="button button--secondary button--full" type="submit" name="update">{{ 'cart.general.update' | t }}</button>
          <button class="button button--full" type="submit" name="checkout">{{ 'cart.general.checkout' | t }}</button>
        </div>
      </form>
    {%- else -%}
      <div class="empty-state"><p>{{ 'cart.general.empty' | t }}</p><a class="button" href="{{ routes.all_products_collection_url }}">{{ 'cart.general.continue_shopping' | t }}</a></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Cart items" }
{% endschema %}
