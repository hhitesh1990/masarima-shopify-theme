<section class="section-spacing">
  <div class="page-width">
    <h1>{{ page_title }}</h1>
    <div class="grid grid--3">
      {%- for collection in collections -%}
        {%- unless collection.handle == 'frontpage' -%}
          <a class="collection-card" href="{{ collection.url }}">
            <div class="collection-card__media">{% if collection.featured_image %}{{ collection.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: collection.title | escape }}{% endif %}</div>
            <h2 class="h3">{{ collection.title }}</h2>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "List collections" }
{% endschema %}
