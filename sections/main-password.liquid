<section class="password-card">
  <h1>{{ shop.name }}</h1>
  <p>{{ 'general.password_page.opening_soon' | t }}</p>
  {%- form 'storefront_password', class: 'product-form' -%}
    <label class="field" for="Password">{{ 'general.password_page.login_form_password_label' | t }}<input id="Password" type="password" name="password"></label>
    <button class="button" type="submit">{{ 'general.password_page.login_form_submit' | t }}</button>
  {%- endform -%}
</section>

{% schema %}
{ "name": "Password" }
{% endschema %}
