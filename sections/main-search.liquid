<section class="section-spacing">
  <div class="page-width">
    <h1>{{ 'templates.search.title' | t }}</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" class="newsletter-form">
      <input type="hidden" name="type" value="product,article,page">
      <input class="input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'templates.search.placeholder' | t }}" aria-label="{{ 'templates.search.search_for' | t }}">
      <button class="button" type="submit">{{ 'templates.search.submit' | t }}</button>
    </form>
    {%- if search.performed -%}
      <h2>{{ 'templates.search.results_for' | t: terms: search.terms }}</h2>
      {%- paginate search.results by section.settings.results_per_page -%}
        {%- if search.results_count > 0 -%}
          <div class="grid grid--3">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {% render 'product-card', product: item %}
              {%- else -%}
                <article class="content-card"><h3><a href="{{ item.url }}">{{ item.title }}</a></h3><p>{{ item.content | strip_html | truncate: 140 }}</p></article>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {% render 'pagination', paginate: paginate %}
        {%- else -%}
          <p>{{ 'templates.search.no_results' | t }}</p>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "settings": [
    { "type": "range", "id": "results_per_page", "label": "Results per page", "min": 6, "max": 36, "step": 3, "default": 12 }
  ]
}
{% endschema %}
