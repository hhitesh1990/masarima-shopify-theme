<section class="newsletter section-spacing">
  <div class="page-width newsletter__inner">
    <div>
      <p class="hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2>{{ section.settings.heading | escape }}</h2>
      <div class="rte">{{ section.settings.text }}</div>
    </div>
    {%- form 'customer', class: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input class="input" type="email" name="contact[email]" aria-label="{{ 'newsletter.label' | t }}" placeholder="{{ 'newsletter.label' | t }}" required>
      <button class="button" type="submit">{{ 'newsletter.button_label' | t }}</button>
      {%- if form.posted_successfully? -%}<p class="form-status">{{ 'newsletter.success' | t }}</p>{%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in the loop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fresh finds, thoughtful offers" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Send updates people actually want to open.</p>" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
