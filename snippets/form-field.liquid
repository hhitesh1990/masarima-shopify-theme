{%- liquid
  assign field_type = type | default: 'text'
  assign field_id = id | default: name
  assign field_label = label | default: name
-%}

<div class="field{% if error != blank %} field--error{% endif %}">
  {%- unless field_type == 'checkbox' or field_type == 'radio' -%}
    <label class="field__label" for="{{ field_id }}">{{ field_label }}</label>
  {%- endunless -%}

  {%- case field_type -%}
    {%- when 'textarea' -%}
      <textarea class="field__control textarea" id="{{ field_id }}" name="{{ name }}"{% if required %} required{% endif %} placeholder="{{ placeholder | escape }}">{{ value }}</textarea>
    {%- when 'select' -%}
      <select class="field__control select" id="{{ field_id }}" name="{{ name }}"{% if required %} required{% endif %}>{{ options }}</select>
    {%- when 'checkbox', 'radio' -%}
      <label class="{{ field_type }}" for="{{ field_id }}"><input id="{{ field_id }}" type="{{ field_type }}" name="{{ name }}" value="{{ value | default: '1' }}"{% if checked %} checked{% endif %}{% if required %} required{% endif %}>{{ field_label }}</label>
    {%- else -%}
      <input class="field__control input" id="{{ field_id }}" type="{{ field_type }}" name="{{ name }}" value="{{ value | escape }}"{% if required %} required{% endif %} placeholder="{{ placeholder | escape }}">
  {%- endcase -%}

  {%- if help_text != blank -%}<p class="field__message">{{ help_text }}</p>{%- endif -%}
  {%- if error != blank -%}<p class="field__message field__message--error">{{ error }}</p>{%- endif -%}
</div>
