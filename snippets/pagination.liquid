{%- if paginate.pages > 1 -%}
  <nav class="pagination" role="navigation" aria-label="Pagination">
    {%- if paginate.previous -%}
      <a href="{{ paginate.previous.url }}" aria-label="Previous page">&lsaquo;</a>
    {%- endif -%}
    {%- for part in paginate.parts -%}
      {%- if part.is_link -%}
        <a href="{{ part.url }}" aria-label="Page {{ part.title }}">{{ part.title }}</a>
      {%- else -%}
        <span class="{% if part.title == paginate.current_page %}current{% endif %}" aria-current="page">{{ part.title }}</span>
      {%- endif -%}
    {%- endfor -%}
    {%- if paginate.next -%}
      <a href="{{ paginate.next.url }}" aria-label="Next page">&rsaquo;</a>
    {%- endif -%}
  </nav>
{%- endif -%}
