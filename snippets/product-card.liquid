{%- if product != blank -%}
  <article class="product-card card" data-card-type="product">
    {%- if product.featured_media != blank -%}
      <a class="product-card__media media media--{{ settings.default_media_ratio }}" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
        {% render 'responsive-image', image: product.featured_media.preview_image, sizes: '(min-width: 990px) 25vw, 50vw', alt: product.title %}
      </a>
    {%- endif -%}
    <div class="product-card__meta">
      {%- if product.vendor != blank -%}<p class="card__eyebrow">{{ product.vendor }}</p>{%- endif -%}
      <h3 class="product-card__title h5"><a href="{{ product.url }}">{{ product.title }}</a></h3>
      <p class="product-card__price">{{ product.price | money }}</p>
    </div>
  </article>
{%- endif -%}
