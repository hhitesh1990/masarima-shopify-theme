{%- liquid
  assign card_product = product
  assign ratio = settings.product_card_image_ratio
  if ratio == 'square'
    assign ratio_value = '1 / 1'
  elsif ratio == 'landscape'
    assign ratio_value = '4 / 3'
  else
    assign ratio_value = '4 / 5'
  endif
-%}

<article class="product-card" style="--card-ratio: {{ ratio_value }};">
  <a class="product-card__media" href="{{ card_product.url }}" aria-label="{{ card_product.title | escape }}">
    {%- if card_product.featured_media -%}
      {%- assign image_alt = card_product.featured_media.alt | default: card_product.title | escape -%}
      {{ card_product.featured_media.preview_image | image_url: width: 720 | image_tag: loading: 'lazy', widths: '320, 480, 640, 720', sizes: '(min-width: 990px) 25vw, 50vw', alt: image_alt }}
    {%- endif -%}
    {%- if card_product.compare_at_price > card_product.price -%}
      <span class="product-card__badge">Sale</span>
    {%- elsif card_product.available == false -%}
      <span class="product-card__badge">{{ 'products.product.sold_out' | t }}</span>
    {%- endif -%}
  </a>
  <div class="product-card__content">
    {%- if card_product.vendor != blank -%}
      <p class="product-card__vendor">{{ card_product.vendor }}</p>
    {%- endif -%}
    <h3 class="product-card__title"><a href="{{ card_product.url }}">{{ card_product.title }}</a></h3>
    {% render 'price', product: card_product %}
  </div>
</article>
